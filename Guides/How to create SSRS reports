Add the fields to the table fields node 

2. Create a Contract class 
   use the DataContarct attribute

[DataContract]
class NSI_EmployeeReportContract
{
    FromDate fromDate;
    ToDate   toDate;

    [DataMember]
    public FromDate parmFromDate(FromDate _fromDate = fromDate)
    {
        fromDate = _fromDate;
        return fromDate;
    }

    [DataMember]
    public ToDate parmToDate(ToDate _toDate = toDate)
    {
        toDate = _toDate;
        return toDate;
    }
}


3. Create a Dp Class 
[SrsReportParameterAttribute(classStr(NSI_EmployeeReportContract))]
the calss should extend with the SRSReportDataProviderBase

[SrsReportParameterAttribute(classStr(NSI_EmployeeReportContract))]
class NSI_EmployeeReportDP extends SRSReportDataProviderBase
{
    NSI_EmployeeReportTmp employeeTmp;

    [SrsReportDataSetAttribute(tableStr(NSI_EmployeeReportTmp))]
    public NSI_EmployeeReportTmp getEmployeeTmp()
    {
        return employeeTmp;
    }

    public void processReport()
    {
        employeeTmp.clear();
        employeeTmp.NSI_EmployeeID   = "1001";
        employeeTmp.NSI_EmployeeName = "Ram";
        employeeTmp.NSI_Department   = "finance";
        employeeTmp.NSI_JoiningDate  = today();
        employeeTmp.NSI_Salary       = 70000;
        employeeTmp.insert();

        employeeTmp.clear();
        employeeTmp.NSI_EmployeeID   = "1002";
        employeeTmp.NSI_EmployeeName = "ishan";
        employeeTmp.NSI_Department   = "IT";
        employeeTmp.NSI_JoiningDate  = today() - 10;
        employeeTmp.NSI_Salary       = 80000;
        employeeTmp.insert();
    }
}

4. Create a Controllere Class 
 extends SrsReportRunController

class NSI_EmployeeReportController extends SrsReportRunController
{
    public static void main(Args _args)
    {
        NSI_EmployeeReportController controller = new NSI_EmployeeReportController();

        controller.parmReportName(ssrsReportStr(NSI_EmployeeReport, Report));
        controller.parmArgs(_args);
        controller.startOperation();
    }
}

